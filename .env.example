# =========================================================================
# 인사장(Insajang) 배포용 환경변수 템플릿 (.env.example)
#
# 이 파일을 복사하여 .env 파일을 만들고 필요한 실제 값들을 입력하세요.
# 주의: .env 파일은 절대 Git에 커밋하지 마세요 (보안 위협).
# =========================================================================

# 1. Google Gemini API 키 (파이썬 AI 피드백/이미지 생성용)
GEMINI_API_KEY=your_gemini_api_key_here

# 2. 이메일 알림 전송용 계정 정보 (Spring Boot 백엔드 메일 기능용)
# 예: Gmail을 사용하는 경우 Google 계정 보안설정에서 '앱 비밀번호(App Password)'를 생성해서 입력해야 합니다.
MAIL_USERNAME=your_email_address@gmail.com
MAIL_PASSWORD=your_app_specific_password_here
